{
  "name": "raccoon-cal-server",
  "version": "1.0.0",
  "description": "浣熊卡路里服务端 - AI驱动的饮食管理应用后端服务",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter server dev",
    "db:setup": "pnpm --filter @raccoon-cal/server run db:setup",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "test:integration": "pnpm --filter server test:integration",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "postinstall": "husky install",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.10.0",
  "keywords": [
    "express",
    "nodejs",
    "mongodb",
    "redis",
    "ai",
    "food-tracking",
    "api",
    "backend",
    "calorie-counter"
  ],
  "author": "RaccoonCal Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/name718/raccoon-cal-server.git"
  },
  "bugs": {
    "url": "https://github.com/name718/raccoon-cal-server/issues"
  },
  "homepage": "https://github.com/name718/raccoon-cal-server#readme",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
